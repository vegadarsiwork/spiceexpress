<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Client MIS Report - <%= customer && (customer.company || customer.name || customer.code) %>
    </title>
    <style>
        @page {
            margin: 8mm;
            size: A4 landscape;
        }

        *,
        *:before,
        *:after {
            box-sizing: border-box;
        }

        html,
        body {
            height: 100%;
            margin: 0;
            padding: 0;
            font-family: 'Helvetica', Arial, sans-serif;
            color: #222;
            font-size: 9px;
            line-height: 1.3;
        }

        .page {
            width: 100%;
            padding: 0;
        }

        .container {
            width: 100%;
            margin: 0 auto;
        }

        /* Header */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 12px;
            padding-bottom: 8px;
            border-bottom: 2px solid #c41e3a;
        }

        .logo img {
            height: 40px;
            width: auto;
        }

        .logo-text {
            font-size: 24px;
            font-weight: 300;
            color: #1a1a1a;
        }

        .logo-text .se {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 30px;
            height: 30px;
            border: 2px solid #c41e3a;
            border-radius: 50%;
            font-size: 12px;
            font-weight: 600;
            color: #c41e3a;
            margin-right: 6px;
        }

        .report-title {
            text-align: right;
        }

        .report-title h1 {
            margin: 0;
            font-size: 18px;
            color: #c41e3a;
        }

        .report-title .date {
            font-size: 10px;
            color: #666;
            margin-top: 4px;
        }

        /* Customer Info */
        .customer-info {
            display: flex;
            gap: 20px;
            margin-bottom: 12px;
            padding: 10px;
            background: #f9f9f9;
            border-radius: 4px;
        }

        .customer-info .block {
            flex: 1;
        }

        .customer-info .label {
            font-weight: 700;
            color: #c41e3a;
            font-size: 9px;
        }

        .customer-info .value {
            font-size: 11px;
            font-weight: 600;
        }

        /* Summary cards */
        .summary-row {
            display: flex;
            gap: 12px;
            margin-bottom: 12px;
        }

        .summary-card {
            flex: 1;
            padding: 10px;
            background: linear-gradient(135deg, #c41e3a 0%, #e85d04 100%);
            color: #fff;
            border-radius: 6px;
            text-align: center;
        }

        .summary-card .title {
            font-size: 9px;
            opacity: 0.9;
            margin-bottom: 4px;
        }

        .summary-card .value {
            font-size: 16px;
            font-weight: 700;
        }

        /* Data table */
        .data-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 8px;
            margin-bottom: 10px;
        }

        .data-table th,
        .data-table td {
            border: 1px solid #ddd;
            padding: 5px 6px;
            text-align: left;
        }

        .data-table th {
            background: #c41e3a;
            color: #fff;
            font-weight: 600;
            text-align: center;
        }

        .data-table td {
            text-align: center;
        }

        .data-table td.left {
            text-align: left;
        }

        .data-table td.right {
            text-align: right;
        }

        .data-table tr:nth-child(even) {
            background: #f9f9f9;
        }

        .data-table .total-row {
            background: #333 !important;
            color: #fff;
            font-weight: 700;
        }

        /* Footer */
        .footer-bar {
            background: linear-gradient(90deg, #c41e3a 0%, #e85d04 100%);
            color: #fff;
            padding: 10px 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 12px;
            border-radius: 4px;
        }

        .footer-bar .company {
            font-weight: 600;
        }

        .footer-bar .tagline {
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 2px;
        }
    </style>
</head>

<body>
    <div class="page">
        <div class="container">
            <!-- Header -->
            <div class="header">
                <div class="logo">
                    <div class="logo-text">
                        <span class="se">SE</span>spice express
                    </div>
                </div>
                <div class="report-title">
                    <h1>Client MIS Report</h1>
                    <div class="date">Generated: <%= generatedDate %>
                    </div>
                </div>
            </div>

            <!-- Customer Info -->
            <div class="customer-info">
                <div class="block">
                    <div class="label">Customer Name</div>
                    <div class="value">
                        <%= customer && (customer.company || customer.name) ? (customer.company || customer.name) : '-'
                            %>
                    </div>
                </div>
                <div class="block">
                    <div class="label">Customer Code</div>
                    <div class="value">
                        <%= customer && customer.code ? customer.code : '-' %>
                    </div>
                </div>
                <div class="block">
                    <div class="label">GSTIN</div>
                    <div class="value">
                        <%= customer && customer.gstin ? customer.gstin : '-' %>
                    </div>
                </div>
                <div class="block">
                    <div class="label">Address</div>
                    <div class="value">
                        <%= customer && customer.address ? customer.address : '-' %>
                    </div>
                </div>
            </div>

            <!-- Summary Cards -->
            <div class="summary-row">
                <div class="summary-card">
                    <div class="title">Total Shipments</div>
                    <div class="value">
                        <%= totalOrders %>
                    </div>
                </div>
                <div class="summary-card">
                    <div class="title">Total Freight</div>
                    <div class="value">₹<%= totalFreight ? totalFreight.toLocaleString('en-IN', {minimumFractionDigits:
                            2}) : '0.00' %>
                    </div>
                </div>
                <div class="summary-card">
                    <div class="title">Total Amount</div>
                    <div class="value">₹<%= totalAmount ? totalAmount.toLocaleString('en-IN', {minimumFractionDigits:
                            2}) : '0.00' %>
                    </div>
                </div>
            </div>

            <!-- Shipment Details Table -->
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 5%">S.No</th>
                        <th style="width: 10%">LR No</th>
                        <th style="width: 9%">Date</th>
                        <th style="width: 10%">Origin</th>
                        <th style="width: 10%">Destination</th>
                        <th style="width: 7%">Pkgs</th>
                        <th style="width: 8%">Act. Wt</th>
                        <th style="width: 8%">Chg. Wt</th>
                        <th style="width: 9%">Freight</th>
                        <th style="width: 9%">Total</th>
                        <th style="width: 8%">Status</th>
                        <th style="width: 8%">Payment</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (lrs && lrs.length> 0) { %>
                        <% let runningFreight=0; let runningTotal=0; %>
                            <% lrs.forEach(function(lr, index) { %>
                                <% const freight=lr.charges?.freight || 0; const total=lr.charges?.total || 0;
                                    runningFreight +=freight; runningTotal +=total; %>
                                    <tr>
                                        <td>
                                            <%= index + 1 %>
                                        </td>
                                        <td class="left">
                                            <%= lr.lrNumber %>
                                        </td>
                                        <td>
                                            <%= lr.bookingDate ? new Date(lr.bookingDate).toLocaleDateString('en-IN')
                                                : '-' %>
                                        </td>
                                        <td class="left">
                                            <%= lr.consignor?.city || '-' %>
                                        </td>
                                        <td class="left">
                                            <%= lr.consignee?.city || '-' %>
                                        </td>
                                        <td>
                                            <%= lr.shipmentDetails?.numberOfArticles || 0 %>
                                        </td>
                                        <td>
                                            <%= lr.shipmentDetails?.actualWeight || 0 %>
                                        </td>
                                        <td>
                                            <%= lr.shipmentDetails?.chargedWeight || 0 %>
                                        </td>
                                        <td class="right">
                                            <%= freight.toLocaleString('en-IN', {minimumFractionDigits: 2}) %>
                                        </td>
                                        <td class="right">
                                            <%= total.toLocaleString('en-IN', {minimumFractionDigits: 2}) %>
                                        </td>
                                        <td>
                                            <%= lr.status || '-' %>
                                        </td>
                                        <td>
                                            <%= lr.charges?.paymentType || '-' %>
                                        </td>
                                    </tr>
                                    <% }); %>
                                        <tr class="total-row">
                                            <td colspan="8" style="text-align: right; padding-right: 10px;">TOTAL</td>
                                            <td class="right">
                                                <%= totalFreight.toLocaleString('en-IN', {minimumFractionDigits: 2}) %>
                                            </td>
                                            <td class="right">
                                                <%= totalAmount.toLocaleString('en-IN', {minimumFractionDigits: 2}) %>
                                            </td>
                                            <td colspan="2"></td>
                                        </tr>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="12" style="text-align: center; padding: 20px;">No shipments
                                                    found</td>
                                            </tr>
                                            <% } %>
                </tbody>
            </table>

            <!-- Footer -->
            <div class="footer-bar">
                <div class="company">SPICE EXPRESS | www.spiceexpress.in | info@spiceexpress.co.in</div>
                <div class="tagline">SPEED YOU TRUST</div>
            </div>

        </div>
    </div>
</body>

</html>