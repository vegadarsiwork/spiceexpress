<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Tax Invoice - <%= invoice && (invoice.invoiceNo || invoice.invoiceNumber) ? (invoice.invoiceNo ||
      invoice.invoiceNumber) : '' %>
  </title>
  <style>
    @page {
      margin: 8mm;
    }

    *,
    *:before,
    *:after {
      box-sizing: border-box;
    }

    html,
    body {
      height: 100%;
      margin: 0;
      padding: 0;
      font-family: 'Helvetica', Arial, sans-serif;
      color: #222;
      font-size: 10px;
      line-height: 1.4;
    }

    .page {
      width: 100%;
      padding: 0;
    }

    .container {
      width: 100%;
      max-width: 700px;
      margin: 0 auto;
    }

    /* Header */
    .header {
      margin-bottom: 8px;
    }

    .logo-row {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 4px;
    }

    .logo img {
      height: 40px;
      width: auto;
    }

    .logo-text {
      font-size: 28px;
      font-weight: 300;
      color: #1a1a1a;
      letter-spacing: 2px;
    }

    .logo-text .se {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      border: 2px solid #c41e3a;
      border-radius: 50%;
      font-size: 14px;
      font-weight: 600;
      color: #c41e3a;
      margin-right: 8px;
    }

    .original-label {
      font-size: 11px;
      color: #c41e3a;
      font-style: italic;
      margin-bottom: 10px;
    }

    .invoice-title {
      text-align: center;
      font-size: 20px;
      font-weight: 700;
      color: #1a1a1a;
      text-decoration: underline;
      margin: 10px 0 15px 0;
    }

    /* FROM/TO Section */
    .from-to {
      display: flex;
      gap: 20px;
      margin-bottom: 12px;
    }

    .from-block,
    .to-block {
      flex: 1;
      font-size: 10px;
    }

    .from-block .label,
    .to-block .label {
      font-weight: 700;
      margin-bottom: 4px;
    }

    .from-block .content,
    .to-block .content {
      line-height: 1.5;
    }

    /* Main content grid */
    .main-grid {
      display: flex;
      gap: 12px;
      margin-bottom: 10px;
    }

    .left-section {
      flex: 1;
    }

    .right-section {
      width: 240px;
    }

    /* Summary table */
    .summary-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 10px;
      margin-bottom: 10px;
    }

    .summary-table th,
    .summary-table td {
      border: 1px solid #c41e3a;
      padding: 5px 8px;
      text-align: left;
    }

    .summary-table th {
      background: #fff;
      color: #c41e3a;
      font-weight: 700;
    }

    .summary-header {
      background: #c41e3a !important;
      color: #fff !important;
      text-align: center;
    }

    /* Invoice details table */
    .invoice-details {
      width: 100%;
      border-collapse: collapse;
      font-size: 10px;
    }

    .invoice-details td {
      border: 1px solid #c41e3a;
      padding: 5px 8px;
    }

    .invoice-details .label {
      font-weight: 700;
      background: #fff;
    }

    .invoice-details .value {
      text-align: right;
    }

    /* Line items table */
    .lines-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 10px;
      margin-bottom: 6px;
    }

    .lines-table th,
    .lines-table td {
      border: 1px solid #c41e3a;
      padding: 6px 8px;
    }

    .lines-table th {
      background: #c41e3a;
      color: #fff;
      font-weight: 600;
    }

    .lines-table td.right {
      text-align: right;
    }

    .lines-table .total-row td {
      font-weight: 700;
    }

    /* Charges breakdown */
    .charges-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 10px;
      margin-bottom: 6px;
    }

    .charges-table td {
      border: 1px solid #c41e3a;
      padding: 5px 8px;
    }

    .charges-table .label {
      width: 70%;
    }

    .charges-table .value {
      text-align: right;
      width: 30%;
    }

    .charges-table .total {
      background: #c41e3a;
      color: #fff;
      font-weight: 700;
    }

    /* Description line */
    .description-line {
      font-size: 10px;
      margin-bottom: 6px;
    }

    .description-line strong {
      font-weight: 700;
    }

    /* Amount in words */
    .amount-words {
      font-size: 10px;
      margin-bottom: 10px;
      padding: 6px 8px;
      border: 1px solid #c41e3a;
      background: #fff;
    }

    .amount-words strong {
      font-weight: 700;
    }

    /* Terms and signature section */
    .terms-signature {
      display: flex;
      gap: 20px;
      margin-bottom: 10px;
    }

    .terms-block {
      flex: 1;
      font-size: 9px;
    }

    .terms-block h4 {
      font-weight: 700;
      margin: 0 0 6px 0;
      font-size: 10px;
    }

    .terms-block ol {
      margin: 0;
      padding-left: 14px;
    }

    .terms-block li {
      margin-bottom: 3px;
    }

    .signature-block {
      width: 180px;
      text-align: center;
    }

    .signature-block .company {
      font-weight: 700;
      margin-bottom: 40px;
    }

    .signature-block .auth {
      font-size: 10px;
      border-top: 1px solid #333;
      padding-top: 4px;
    }

    /* Bank details */
    .bank-details {
      display: flex;
      border: 1px solid #c41e3a;
      font-size: 10px;
      margin-bottom: 8px;
    }

    .bank-details .cell {
      flex: 1;
      padding: 6px 8px;
      border-right: 1px solid #c41e3a;
    }

    .bank-details .cell:last-child {
      border-right: none;
    }

    .bank-details .label {
      font-weight: 700;
    }

    /* Disclaimer */
    .disclaimer {
      font-size: 8px;
      color: #444;
      margin-bottom: 12px;
      line-height: 1.4;
      text-align: justify;
    }

    .disclaimer strong {
      font-weight: 700;
    }

    /* Footer company info */
    .footer-info {
      font-size: 10px;
      margin-bottom: 10px;
      line-height: 1.5;
    }

    .footer-info strong {
      font-weight: 700;
    }

    /* Colored footer bar */
    .footer-bar {
      background: linear-gradient(90deg, #c41e3a 0%, #e85d04 100%);
      color: #fff;
      padding: 12px 20px;
      display: flex;
      justify-content: flex-end;
      align-items: center;
      margin-top: 10px;
    }

    .footer-bar .tagline {
      font-size: 14px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
    }
  </style>
</head>

<body>
  <div class="page">
    <div class="container">
      <!-- Header -->
      <div class="header">
        <div class="logo-row">
          <div class="logo">
            <% if (logoBase64) { %>
              <img src="<%= logoBase64 %>" alt="<%= company && company.name ? company.name : 'Company Logo' %>"
                style="height: 80px; width: auto;" />
              <% } %>
          </div>
        </div>
        <div class="original-label">Original For Recipient</div>
      </div>

      <div class="invoice-title">TAX INVOICE</div>

      <!-- FROM / TO Section -->
      <div class="from-to">
        <div class="from-block">
          <div class="label">FROM</div>
          <div class="content">
            <strong>
              <%= company && company.name ? company.name : (invoice && invoice.supplierName ? invoice.supplierName
                : 'SPICE EXPRESS' ) %>
            </strong><br />
            <%= company && company.address ? company.address : (invoice && invoice.billingAddress ?
              invoice.billingAddress : 'Block D, Plot No. D 464, Martin nagar, Mankapur, Nagpur - 440002' ) %><br />
              State Code (LOS) : <%= company && company.stateCode ? company.stateCode : '27' %> - <%= company &&
                  company.state ? company.state : 'Maharashtra' %><br />
                  GSTIN : <%= company && company.gstin ? company.gstin : (invoice && invoice.supplierGstin ?
                    invoice.supplierGstin : '27AEMFS2408G1ZY' ) %><br />
                    PAN : <%= company && company.pan ? company.pan : 'AEMFS2408G' %><br />
                      HSN Code : <%= company && company.hsnCode ? company.hsnCode : (invoice && invoice.hsn ?
                        invoice.hsn : '9969' ) %>
          </div>
        </div>
        <div class="to-block">
          <div class="label">TO</div>
          <div class="content">
            <strong>
              <%= customer && (customer.name || customer.company) ? (customer.name || customer.company) : '' %>
            </strong><br />
            <%= customer && customer.address ? customer.address : '' %><br />
              State Code (LOS) : <%= customer && customer.state ? customer.state : '' %><br />
                GSTIN : <%= customer && customer.gstin ? customer.gstin : '' %><br />
                  PAN : <%= customer && customer.pan ? customer.pan : '' %>
          </div>
        </div>
      </div>

      <!-- Main Grid: Summary + Invoice Details -->
      <div class="main-grid">
        <div class="left-section">
          <table class="summary-table">
            <tr>
              <th colspan="3" class="summary-header">Summary Of Outstanding In Rupees</th>
            </tr>
            <tr>
              <th>Customer Code</th>
              <td colspan="2">
                <%= customer && customer.code ? customer.code : (invoice && invoice.customerCode ? invoice.customerCode
                  : '' ) %>
              </td>
            </tr>
            <tr>
              <th>Trade Name</th>
              <td colspan="2">
                <%= customer && (customer.company || customer.name) ? (customer.company || customer.name) : '' %>
              </td>
            </tr>
            <tr>
              <th>Current Bills</th>
              <th>Past Payment Due</th>
              <th>Total Outstanding</th>
            </tr>
            <tr>
              <td>Rs. <%= invoice && invoice.totalAmount ? invoice.totalAmount.toLocaleString('en-IN',
                  {minimumFractionDigits: 2}) : '0.00' %>
              </td>
              <td>Rs. <%= invoice && invoice.pastDue ? invoice.pastDue.toLocaleString('en-IN', {minimumFractionDigits:
                  2}) : '0.00' %>
              </td>
              <td>Rs. <%= invoice && invoice.totalAmount ? invoice.totalAmount.toLocaleString('en-IN',
                  {minimumFractionDigits: 2}) : '0.00' %>
              </td>
            </tr>
          </table>
        </div>
        <div class="right-section">
          <table class="invoice-details">
            <tr>
              <td class="label">Place of Supply</td>
              <td class="value">
                <%= customer && customer.state ? customer.state : 'Maharashtra' %>
              </td>
            </tr>
            <tr>
              <td class="label">Invoice No.</td>
              <td class="value">
                <%= invoice && (invoice.invoiceNo || invoice.invoiceNumber) ? (invoice.invoiceNo ||
                  invoice.invoiceNumber) : '' %>
              </td>
            </tr>
            <tr>
              <td class="label">Invoice Date</td>
              <td class="value">
                <%= invoice && (invoice.invoiceDate || invoice.date) ? new Date(invoice.invoiceDate ||
                  invoice.date).toLocaleDateString('en-IN') : '' %>
              </td>
            </tr>
            <tr>
              <td class="label">Invoice Due Date</td>
              <td class="value">
                <%= invoice && invoice.dueDate ? new Date(invoice.dueDate).toLocaleDateString('en-IN') : '' %>
              </td>
            </tr>
          </table>
        </div>
      </div>

      <!-- Line Items Table -->
      <table class="lines-table">
        <thead>
          <tr>
            <th style="width: 8%">S.No.</th>
            <th style="width: 62%">Description</th>
            <th style="width: 30%">Invoice Amount</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>1</td>
            <td>Being Transportation Charges as per annexure attached</td>
            <td class="right">Rs. <%= invoice && invoice.freightValue ? invoice.freightValue.toLocaleString('en-IN',
                {minimumFractionDigits: 2}) : '0.00' %>
            </td>
          </tr>
        </tbody>
      </table>

      <!-- Charges Breakdown -->
      <table class="charges-table">
        <tr>
          <td class="label">Total Freight Amount</td>
          <td class="value">Rs. <%= invoice && invoice.freightValue ? invoice.freightValue.toLocaleString('en-IN',
              {minimumFractionDigits: 2}) : '0.00' %>
          </td>
        </tr>
        <tr>
          <td class="label">CGST</td>
          <td class="value">Rs. <%= invoice && invoice.cgst ? invoice.cgst.toLocaleString('en-IN',
              {minimumFractionDigits: 2}) : '0.00' %>
          </td>
        </tr>
        <tr>
          <td class="label">SGST/UGST</td>
          <td class="value">Rs. <%= invoice && invoice.sgst ? invoice.sgst.toLocaleString('en-IN',
              {minimumFractionDigits: 2}) : '0.00' %>
          </td>
        </tr>
        <tr>
          <td class="label">IGST @ <%= invoice && invoice.gstPercent ? invoice.gstPercent : '18' %>.0%</td>
          <td class="value">Rs. <%= invoice && invoice.igst ? invoice.igst.toLocaleString('en-IN',
              {minimumFractionDigits: 2}) : '0.00' %>
          </td>
        </tr>
        <tr>
          <td class="label total">Total Invoice Amount</td>
          <td class="value total">Rs. <%= invoice && invoice.totalAmount ? invoice.totalAmount.toLocaleString('en-IN',
              {minimumFractionDigits: 2}) : '0.00' %>
          </td>
        </tr>
      </table>

      <!-- Description of charges -->
      <div class="description-line">
        <strong>Description of charges:</strong> As per agreed terms
      </div>

      <!-- Amount in Words -->
      <div class="amount-words">
        <strong>In Words:</strong> Rupees <%= invoice && invoice.amountInWords ? invoice.amountInWords : 'Zero Only' %>
      </div>

      <!-- Terms and Signature -->
      <div class="terms-signature">
        <div class="terms-block">
          <h4>Terms and Conditions</h4>
          <ol>
            <li>All payments to be made only through Account Payee Cheque /DD/RTGS in favor of Spice Express.</li>
            <li>Interest @ 2.00% per month or part thereof will be charged if the bill is not paid on due date.</li>
            <li>All disputes and differences arising out of this will be subject to jurisdiction of Nagpur courts only.
            </li>
            <li>Mail your payment advice to info@spiceexpress.co.in. You can also write to info@spiceexpress.co.in for
              any billing related issues.</li>
          </ol>
        </div>
        <div class="signature-block">
          <div class="company">For Spice Express</div>
          <div class="auth">Authorized Signatory</div>
        </div>
      </div>

      <!-- Bank Details -->
      <div class="bank-details">
        <div class="cell"><span class="label">Bank Name:</span>
          <%= company && company.bankName ? company.bankName : 'ICICI Bank Ltd.' %>
        </div>
        <div class="cell"><span class="label">IFSC:</span>
          <%= company && company.ifsc ? company.ifsc : 'ICIC0002027' %>
        </div>
        <div class="cell"><span class="label">MICR:</span> 440229017</div>
      </div>
      <div class="bank-details">
        <div class="cell"><span class="label">Account Name:</span>
          <%= company && company.accountName ? company.accountName : 'SPICE EXPRESS' %>
        </div>
        <div class="cell" style="flex: 2;"><span class="label">Account Number:</span>
          <%= company && company.accountNo ? company.accountNo : '202705002621' %> (CA)
        </div>
      </div>

      <!-- Disclaimer -->
      <div class="disclaimer">
        The electronic signature to this system generated invoice shall be as valid as an original signature of such
        party and shall be effectively binding on <%= customer && (customer.name || customer.company) ? (customer.name
          || customer.company).toUpperCase() : 'THE RECIPIENT' %>. This electronically
          signed invoice shall be deemed (i) to be "written" or "in writing," (ii) to have been signed and (iii) to
          constitute a record established and maintained in the ordinary course of business and an original written
          record
          when printed from electronic files. Such paper copies or "printouts," if introduced as evidence in any
          judicial,
          arbitral, mediation or administrative proceeding, will be admissible between the parties to the same extent as
          physical signed document. <strong>This is a computer generated invoice and needs no signature.</strong>
      </div>

      <!-- Footer Info -->
      <div class="footer-info">
        <strong>
          <%= company && company.name ? company.name : 'SPICE EXPRESS' %>
        </strong><br />
        <strong>Registered Office:</strong>
        <%= company && company.address ? company.address
          : 'Block D, Plot No. D 464, Martin nagar, Mankapur, Nagpur - 440002' %>,
          <%= company && company.state ? company.state : 'Maharashtra' %>.<br />
            <strong>Email:</strong>
            <%= company && company.email ? company.email : 'info@spiceexpress.co.in' %><br />
              <% if (company && company.website) { %><strong>Web:</strong>
                <%= company.website %><br />
                  <% } %>
                    <strong>CIN:</strong>
      </div>

      <!-- Colored Footer Bar -->
      <div class="footer-bar">
        <div class="tagline">SPEED YOU TRUST</div>
      </div>

    </div>
  </div>
</body>

</html>