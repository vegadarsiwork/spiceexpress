<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LR - <%= lr.lrNumber %>
  </title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 20px;
      font-size: 12px;
      line-height: 1.4;
      color: #333;
    }

    .header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 20px;
      border-bottom: 2px solid #000;
      padding-bottom: 10px;
    }

    .header-left {
      flex: 1;
    }

    .header-right {
      flex: 1;
      text-align: right;
    }

    .company-info {
      display: flex;
      align-items: center;
      margin-bottom: 10px;
    }

    .logo-placeholder {
      width: 50px;
      height: 50px;
      background-color: #ff0000;
      border-radius: 50%;
      margin-right: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-weight: bold;
    }

    .company-details h1 {
      margin: 0;
      font-size: 18px;
      font-weight: bold;
    }

    .company-details p {
      margin: 2px 0;
      font-size: 11px;
    }

    .track-info {
      font-size: 10px;
      color: #666;
      margin-top: 5px;
    }

    .consignment-number {
      font-size: 24px;
      font-weight: bold;
      margin-bottom: 5px;
    }

    .origin-destination {
      font-size: 11px;
      margin-bottom: 5px;
    }

    .gst-info {
      font-size: 11px;
      margin-top: 10px;
    }

    .sender-receiver {
      display: flex;
      justify-content: space-between;
      margin-bottom: 20px;
    }

    .sender-section,
    .receiver-section {
      flex: 1;
      margin-right: 20px;
    }

    .section-title {
      font-weight: bold;
      margin-bottom: 5px;
      border-bottom: 1px solid #000;
      padding-bottom: 2px;
    }

    .sender-info,
    .receiver-info {
      font-size: 11px;
      line-height: 1.3;
    }

    .date-packages {
      text-align: right;
      font-size: 11px;
    }

    .consignment-details {
      margin-bottom: 20px;
    }

    .consignment-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 10px;
    }

    .consignment-table th,
    .consignment-table td {
      border: 1px solid #000;
      padding: 8px;
      text-align: center;
      font-size: 11px;
    }

    .consignment-table th {
      background-color: #f0f0f0;
      font-weight: bold;
    }

    .weight-summary {
      text-align: right;
      margin-top: 10px;
    }

    .weight-boxes {
      display: flex;
      justify-content: flex-end;
      gap: 10px;
      margin-bottom: 5px;
    }

    .weight-box {
      border: 1px solid #000;
      padding: 2px 8px;
      font-size: 10px;
    }

    .total-weight {
      font-size: 16px;
      font-weight: bold;
    }

    .declaration-section {
      display: flex;
      justify-content: space-between;
      margin-bottom: 20px;
    }

    .declaration-left {
      flex: 2;
      margin-right: 20px;
    }

    .declaration-right {
      flex: 1;
    }

    .declaration-text {
      font-size: 10px;
      line-height: 1.3;
      margin-bottom: 15px;
    }

    .signature-section {
      margin-top: 20px;
    }

    .signature-line {
      border-bottom: 1px solid #000;
      margin-top: 15px;
      padding-bottom: 5px;
    }

    .received-section {
      font-size: 10px;
    }

    .received-section div {
      margin-bottom: 5px;
    }

    .acknowledgment {
      text-align: right;
      margin-top: 20px;
      font-size: 10px;
    }

    .acknowledgment div {
      margin-bottom: 5px;
    }
  </style>
</head>

<body style="border: 2px solid #000; margin: 16px 16px 16px 16px; padding: 0; background: #fff;">
  <% for (let i=0; i < 2; i++) { %>
    <div
      style="width: 99%; margin: 0 auto 8px auto; border: 1px solid #000; padding: 10px 14px 12px 14px; font-size: 11px; background: #fff; box-sizing: border-box;">
      <div
        style="display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 2px solid #000; padding: 6px 0 4px 0;">
        <div style="flex: 1;">
          <div style="font-size: 9px; color: #444; margin-bottom: 1px;">TRACK @ www.spiceexpress.co.in</div>
          <div style="font-size: 9px; color: #444; margin-bottom: 4px;">Email: julie.douglas@spiceexpress.co.in /
            julie.douglas@spiceexpress.co.in</div>
          <div style="display: flex; align-items: center; margin: 4px 0 0 0;">
            <% if (logoBase64) { %>
              <img src="<%= logoBase64 %>" alt="SPICE"
                style="width: 48px; height: 48px; object-fit: contain; margin-right: 8px;" />
              <% } else { %>
                <div
                  style="width: 32px; height: 32px; background: #ff0000; border-radius: 50%; color: #fff; font-weight: bold; display: flex; align-items: center; justify-content: center; margin-right: 8px; font-size: 10px;">
                  SPICE</div>
                <% } %>
                  <div>
                    <div style="font-size: 14px; font-weight: bold; margin-bottom: 1px;">SPICE EXPRESS</div>
                    <div style="font-size: 9px;">On Time Every Time</div>
                    <div style="font-size: 9px;">Block D, Plot No. D 464, Martin nagar, Mankapur, Nagpur 440002</div>
                  </div>
          </div>
          <div style="font-size: 9px; margin-top: 2px;">GST No.: 27AEMFS2408G1ZY</div>
        </div>
        <div style="flex: 1; text-align: right;">
          <div style="font-size: 16px; font-weight: bold; margin-bottom: 2px;">
            <%= lr.lrNumber %>
          </div>
          <div style="font-size: 10px;">Origin: <%= lr.consignor && lr.consignor.city ? lr.consignor.city : '' %> ,
              Maharashtra</div>
          <div style="font-size: 10px;">Destination: <%= lr.consignee && lr.consignee.city ? lr.consignee.city : '' %> ,
              Madhya Pradesh</div>
        </div>
      </div>
      <div style="display: flex; justify-content: space-between; align-items: flex-start; margin: 4px 0 0 0;">
        <div style="flex: 1; min-width: 0;">
          <div
            style="font-weight: bold; font-size: 11px; border-bottom: 1.5px solid #000; margin-bottom: 2px; padding-bottom: 1px;">
            Sender's Name:</div>
          <div style="font-size: 10px; white-space: pre-line; line-height: 1.2;">
            <%= lr.consignor && lr.consignor.code ? lr.consignor.code + ' - ' : '' %>
              <%= lr.consignor && lr.consignor.name ? lr.consignor.name : '' %>
                <br>
                <%= lr.consignor && lr.consignor.address ? lr.consignor.address : '' %>
                  <br>
                  <%= lr.consignor && lr.consignor.city ? lr.consignor.city : '' %>
          </div>
        </div>
        <div style="flex: 1; min-width: 0;">
          <div
            style="font-weight: bold; font-size: 11px; border-bottom: 1.5px solid #000; margin-bottom: 2px; padding-bottom: 1px;">
            Receiver's Name:</div>
          <div style="font-size: 10px; white-space: pre-line; line-height: 1.2;">
            <%= lr.consignee && lr.consignee.code ? lr.consignee.code + ' - ' : '' %>
              <%= lr.consignee && lr.consignee.name ? lr.consignee.name : '' %>
                <br>
                <%= lr.consignee && lr.consignee.address ? lr.consignee.address : '' %>
                  <br>
                  <%= lr.consignee && lr.consignee.city ? lr.consignee.city : '' %>
          </div>
        </div>
        <div style="flex: 0.6; text-align: right;">
          <div style="font-size: 10px; font-weight: bold; margin-bottom: 2px;">Dt: <%= lr.bookingDate ? new
              Date(lr.bookingDate).toLocaleDateString('en-GB') : '' %>
          </div>
          <div style="font-size: 10px; font-weight: bold;">Packages: <%= lr.shipmentDetails &&
              lr.shipmentDetails.numberOfArticles ? lr.shipmentDetails.numberOfArticles : '' %>
          </div>
        </div>
      </div>
      <table style="width: 100%; border-collapse: collapse; margin: 6px 0 0 0; font-size: 11px;">
        <thead>
          <tr>
            <th style="border: 1.2px solid #000; padding: 3px 0; font-size: 11px; background: #fff; font-weight: bold;">
              CONTENTS</th>
            <th style="border: 1.2px solid #000; padding: 3px 0; font-size: 11px; background: #fff; font-weight: bold;">
              DECLARED VALUE</th>
            <th style="border: 1.2px solid #000; padding: 3px 0; font-size: 11px; background: #fff; font-weight: bold;">
              ACTUAL WT.</th>
            <th style="border: 1.2px solid #000; padding: 3px 0; font-size: 11px; background: #fff; font-weight: bold;">
              CHARGED WT.</th>
            <th style="border: 1.2px solid #000; padding: 3px 0; font-size: 11px; background: #fff; font-weight: bold;">
              MODE</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td style="border: 1.2px solid #000; padding: 3px 0; font-size: 10px; background: #fff; text-align: left;">
              <%= lr.shipmentDetails && lr.shipmentDetails.descriptionOfGoods ? lr.shipmentDetails.descriptionOfGoods
                : '' %>
            </td>
            <td style="border: 1.2px solid #000; padding: 3px 0; font-size: 10px; background: #fff; text-align: right;">
              <%= lr.customerInvoice && lr.customerInvoice.value ? lr.customerInvoice.value : '' %>
            </td>
            <td style="border: 1.2px solid #000; padding: 3px 0; font-size: 10px; background: #fff; text-align: right;">
              <%= lr.shipmentDetails && lr.shipmentDetails.actualWeight ?
                Number(lr.shipmentDetails.actualWeight).toFixed(3) : '0.000' %>
            </td>
            <td style="border: 1.2px solid #000; padding: 3px 0; font-size: 10px; background: #fff; text-align: right;">
              <%= lr.shipmentDetails && lr.shipmentDetails.chargedWeight ?
                Number(lr.shipmentDetails.chargedWeight).toFixed(3) : '0.000' %>
            </td>
            <td
              style="border: 1.2px solid #000; padding: 3px 0; font-size: 10px; background: #fff; text-align: center;">
              <%= lr.transportType || '' %>
            </td>
          </tr>
        </tbody>
      </table>
      <div style="display: flex; align-items: flex-end; margin-top: 6px;">
        <div style="flex: 1;">
          <div style="font-size: 9px; margin-top: 4px; line-height: 1.2;">I/We declare that this consignment does not
            contain personal mail,cash,contraband,illegal drugs,any prohibited items and commodities which can cause
            safety hazzrds while transported by air and surface.<br>Non Negotiable Consignment Note/Subject to Nagpur
            Jurisdiction.Please refer to all the terms & conditions printed overleaf of this consignment note.</div>
          <div style="font-size: 10px; margin-top: 6px;">SENDER'S
            SIGN:.......................................................</div>
        </div>
        <div style="flex: 1;">
          <div style="font-size: 9px; font-weight: bold; margin-bottom: 2px;">RECEIVED IN GOOD CONDITION</div>
          <div style="font-size: 9px;">Sign & Seal ...............................</div>
          <div style="font-size: 9px;">Name.............................................</div>
          <div style="font-size: 9px;">Relation........................................</div>
          <div style="font-size: 9px;">Mobile No:....................................</div>
          <div style="font-size: 9px;">I.D. No.:........................................</div>
        </div>
        <div style="flex: 0.7; text-align: right;">
          <div style="font-size: 10px; font-weight: bold;">For, The SPICE EXPRESS</div>
          <div style="font-size: 9px;">Booking Branch / FR Code</div>
          <div style="font-size: 9px;">Dt:...... Sign:.............</div>
          <div style="display: flex; align-items: center; margin-top: 6px;">
            <div
              style="border: 1.2px solid #000; padding: 5px 10px; font-size: 12px; font-weight: bold; margin-right: 6px;">
              KG</div>
            <div style="border: 1.2px solid #000; padding: 5px 10px; font-size: 12px; font-weight: bold;">GMS</div>
          </div>
          <div style="font-size: 18px; font-weight: bold; margin-top: 2px;">
            <%= lr.shipmentDetails && lr.shipmentDetails.chargedWeight ?
              Number(lr.shipmentDetails.chargedWeight).toFixed(3) : '0.000' %>
          </div>
        </div>
      </div>
    </div>
    <% if (i===0) { %>
      <div style="border-bottom: 2px solid #000; margin: 6px 0 0 0;"></div>
      <% } %>
        <% } %>
</body>

</html>